{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID from Firebase Auth" },
        "displayName": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "photoURL": { "type": "string", "description": "User's profile picture URL" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp" },
        "savedPlaces": {
          "type": "object",
          "description": "User's saved locations like Home and Work",
          "properties": {
            "home": { "type": "string" },
            "work": { "type": "string" }
          }
        }
      },
      "required": ["uid", "email"]
    },
    "Ride": {
      "title": "Ride Information",
      "description": "Stores details of a ride request.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID of the rider" },
        "pickup": { "type": "string", "description": "Pickup location name" },
        "destination": { "type": "string", "description": "Destination location name" },
        "pickupCoords": { "type": "array", "items": { "type": "number" }, "description": "Latitude and longitude of pickup" },
        "destCoords": { "type": "array", "items": { "type": "number" }, "description": "Latitude and longitude of destination" },
        "price": { "type": "string", "description": "Total fare in JOD" },
        "type": { "type": "string", "description": "Ride service type (e.g., Economy, Business)" },
        "status": { "type": "string", "enum": ["Active", "Completed", "Cancelled", "Scheduled"], "description": "Current status of the ride" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the ride was booked" },
        "driver": {
          "type": "object",
          "properties": {
            "name": { "type": "string" },
            "car": { "type": "string" },
            "plate": { "type": "string" },
            "rating": { "type": "number" }
          }
        },
        "rating": { "type": "number", "description": "User rating for the ride (1-5)" },
        "review": { "type": "string", "description": "User review for the ride" }
      },
      "required": ["uid", "pickup", "destination", "price", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents"
    },
    "/rides/{rideId}": {
      "schema": "Ride",
      "description": "Ride history and active ride documents"
    }
  }
}
